# ============================================================
# Claude Telegram Bot — переменные окружения
# Скопируй этот файл в .env и заполни значения
# ============================================================

# ----------------------------------------------------------
# Telegram Bot Token
# Получить: @BotFather → /newbot
# ----------------------------------------------------------
BOT_TOKEN=your_telegram_bot_token_here

# ----------------------------------------------------------
# Anthropic API Key (Claude)
# Получить: https://console.anthropic.com/
# ----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ----------------------------------------------------------
# Groq API Key (Whisper STT — бесплатный tier доступен)
# Получить: https://console.groq.com/
# ----------------------------------------------------------
GROQ_API_KEY=gsk_your_key_here

# ----------------------------------------------------------
# Replicate API Token (генерация изображений и видео)
# Получить: https://replicate.com/account/api-tokens
# ----------------------------------------------------------
REPLICATE_API_TOKEN=r8_your_token_here

# ----------------------------------------------------------
# Telegram Owner ID — только этот пользователь имеет доступ
# Узнать свой ID: @userinfobot в Telegram
# ----------------------------------------------------------
OWNER_TELEGRAM_ID=123456789

# ----------------------------------------------------------
# Telegram Channel ID для публикации постов
# Формат: -100XXXXXXXXXX (числовой ID канала)
# Или: @channel_username (публичный канал)
# Бот должен быть администратором канала с правом публикации
# ----------------------------------------------------------
CHANNEL_ID=-1001234567890

# ----------------------------------------------------------
# Telethon credentials (опционально — для парсинга TG-каналов)
# Получить: https://my.telegram.org/apps
# Без этих переменных парсинг TG-каналов будет недоступен
# ----------------------------------------------------------
TELETHON_API_ID=
TELETHON_API_HASH=
TELETHON_PHONE=+79001234567
