# ═══════════════════════════════════════════
# AI Content Autopilot — Environment Variables
# ═══════════════════════════════════════════

# ─── ОБЯЗАТЕЛЬНЫЕ ─────────────────────────
TELEGRAM_BOT_TOKEN=         # Токен бота от @BotFather
ANTHROPIC_API_KEY=          # API ключ с console.anthropic.com
OWNER_TELEGRAM_ID=          # Ваш Telegram user ID (число)

# ─── КАНАЛЫ (опционально) ─────────────────
TELEGRAM_CHANNEL_ID=        # ID канала для публикации (например: @mychannel или -1001234567890)
VK_API_TOKEN=               # Токен VK API (из vk.com/dev)
VK_GROUP_ID=                # ID группы VK (без минуса)
